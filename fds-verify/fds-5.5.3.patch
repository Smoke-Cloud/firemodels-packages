+CALL JSON%ADD(OBJ1, 'dt_hrr', DT_HRR)
+CALL JSON%ADD(OBJ1, 'dt_isof', DT_ISOF)
+CALL JSON%ADD(OBJ1, 'dt_mass', DT_MASS)
