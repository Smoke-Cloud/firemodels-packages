+         OB => MESHES(NM)%OBSTRUCTION(N)
+         CALL JSON%CREATE_OBJECT(OBJ4,'obst')
+         CALL JSON%ADD(OBJ3, OBJ4)
+         CALL JSON%ADD(OBJ4, 'index', N)
+         ! CALL JSON%ADD(OBJ4, 'id', TRIM(OB%ID))
+
